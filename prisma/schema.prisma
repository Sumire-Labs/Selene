generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Guild {
  id        String   @id // Discord guild snowflake
  prefix    String   @default("/")
  djRoleId  String?  @map("dj_role_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("guilds")
}

model BotSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("bot_settings")
}

model Counter {
  id        Int          @id @default(autoincrement())
  guildId   String       @map("guild_id")
  word      String
  matchType Int          @map("match_type") // 1=partial, 2=exact, 3=word
  createdAt DateTime     @default(now()) @map("created_at")
  logs      CounterLog[]

  @@unique([guildId, word])
  @@index([guildId])
  @@map("counters")
}

model CounterLog {
  id        Int      @id @default(autoincrement())
  counterId Int      @map("counter_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  counter   Counter  @relation(fields: [counterId], references: [id], onDelete: Cascade)

  @@index([counterId, createdAt])
  @@index([counterId, userId])
  @@map("counter_logs")
}

model TicketConfig {
  guildId           String   @id @map("guild_id")
  panelChannelId    String?  @map("panel_channel_id")
  categoryId        String?  @map("category_id")
  supportRoleId     String?  @map("support_role_id")
  panelMessageId    String?  @map("panel_message_id")
  ticketCounter     Int      @default(0) @map("ticket_counter")
  panelTitle        String?  @map("panel_title")
  panelDescription  String?  @map("panel_description")
  maxTicketsPerUser Int      @default(1) @map("max_tickets_per_user")
  autoCloseHours    Int?     @map("auto_close_hours")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("ticket_configs")
}

model LoggerConfig {
  guildId             String   @id @map("guild_id")
  enabled             Boolean  @default(false)
  defaultChannelId    String?  @map("default_channel_id")
  messageChannelId    String?  @map("message_channel_id")
  memberChannelId     String?  @map("member_channel_id")
  moderationChannelId String?  @map("moderation_channel_id")
  serverChannelId     String?  @map("server_channel_id")
  enabledEvents       String[] @map("enabled_events")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("logger_configs")
}

model XpConfig {
  guildId               String         @id @map("guild_id")
  enabled               Boolean        @default(false)
  multiplier            Float          @default(1.0)
  messageXp             Int            @default(20) @map("message_xp")
  voiceXpPerMinute      Int            @default(6) @map("voice_xp_per_minute")
  cooldownSeconds       Int            @default(60) @map("cooldown_seconds")
  notificationMode      String         @default("same") @map("notification_mode")
  notificationChannelId String?        @map("notification_channel_id")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  roleRewards           XpRoleReward[]

  @@map("xp_configs")
}

model UserXp {
  id                Int      @id @default(autoincrement())
  guildId           String   @map("guild_id")
  userId            String   @map("user_id")
  xp                Int      @default(0)
  level             Int      @default(0)
  totalMessages     Int      @default(0) @map("total_messages")
  totalVoiceMinutes Int      @default(0) @map("total_voice_minutes")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([guildId, userId])
  @@index([guildId, xp(sort: Desc)])
  @@map("user_xp")
}

model XpRoleReward {
  id      Int      @id @default(autoincrement())
  guildId String   @map("guild_id")
  level   Int
  roleId  String   @map("role_id")
  config  XpConfig @relation(fields: [guildId], references: [guildId], onDelete: Cascade)

  @@unique([guildId, level])
  @@index([guildId])
  @@map("xp_role_rewards")
}

model EmbedFixConfig {
  guildId   String   @id @map("guild_id")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("embedfix_configs")
}
